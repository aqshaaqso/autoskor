# =============================================================================
# Mode middleware nyata — sesuaikan URL dengan environment Anda
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_USE_MOCK_AUTH=true
VITE_USE_MOCK_ADMIN=true

# Set false ketika middleware sudah menyediakan endpoint auth/admin:
# VITE_USE_MOCK_AUTH=false
# VITE_USE_MOCK_ADMIN=false

VITE_SCORING_JOBS_LIST_LIMIT=100