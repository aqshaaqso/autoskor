# =============================================================================
# Mode middleware nyata — sesuaikan URL dengan environment Anda
# =============================================================================
VITE_API_BASE_URL=http://http://localhost:5173//api
VITE_USE_MOCK=false
VITE_USE_MOCK_DOCUMENTS=false
VITE_USE_MOCK_AUTH=true
VITE_USE_MOCK_ADMIN=true
VITE_USE_MOCK_ENGINE=false

# =============================================================================
# Mode lokal (mock) — untuk laptop baru tanpa koneksi middleware
# Comment blok di atas, uncomment blok di bawah
# =============================================================================
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_USE_MOCK=true
# VITE_USE_MOCK_DOCUMENTS=true
# VITE_USE_MOCK_AUTH=true
# VITE_USE_MOCK_ADMIN=true
# VITE_USE_MOCK_ENGINE=true

VITE_SCORING_JOBS_LIST_LIMIT=100
